# Painel 4Selet — variaveis locais. Copie para .env (ou configure pela UI em Configuracoes).
# A chave NUNCA e versionada (.env esta no .gitignore).
ANTHROPIC_API_KEY=
# Modelo Claude usado para geracao (default: claude-sonnet-4-6)
MODEL=claude-sonnet-4-6
# Porta do servidor local
PORT=4500
# Interface de rede (opcional):
#   127.0.0.1 => acesso SOMENTE local (de dentro da VPS, via RDP) — mais seguro
#   (vazio)   => acessivel por qualquer maquina que alcance a VPS na porta acima
# O painel NAO tem autenticacao; em rede aberta, qualquer um com acesso pode usar.
HOST=127.0.0.1
